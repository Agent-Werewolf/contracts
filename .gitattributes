# Normalize line endings to LF on commit, regardless of platform.
* text=auto eol=lf

# Solidity / config / docs are always text
*.sol     text eol=lf
*.toml    text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf

# Mark vendored dependencies for GitHub language stats
lib/**         linguist-vendored
out/**         linguist-generated
broadcast/**   linguist-generated
cache/**       linguist-generated
